{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write",
    "fs:allow-app-meta",
    "process:allow-exit",
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:scope-home-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-download-recursive"
  ]
}
